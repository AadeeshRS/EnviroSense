<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="ring" android:thicknessRatio="15" android:useLevel="false">
            <solid android:color="@color/surface_dark" />
        </shape>
    </item>
    <item>
        <rotate android:fromDegrees="270" android:toDegrees="270">
            <shape android:shape="ring" android:thicknessRatio="15" android:useLevel="true">
                <gradient android:type="sweep" android:useLevel="false"
                    android:startColor="@color/primary_green"
                    android:endColor="@color/primary_green" />
            </shape>
        </rotate>
    </item>
</layer-list>
