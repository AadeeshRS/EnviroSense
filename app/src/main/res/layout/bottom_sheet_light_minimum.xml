<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#333333"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Light minimum"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Alert when ambient light drops below this level"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="32dp" />
    <TextView
        android:id="@+id/tv_current_light_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="200"
        android:textColor="@color/white"
        android:textSize="48sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="lux"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="24dp" />

    <SeekBar
        android:id="@+id/seekbar_light"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="950"
        android:progress="150"
        android:progressTint="@color/primary_green"
        android:thumbTint="@color/primary_green"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50 lux"
            android:textColor="@color/text_secondary" />
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="dim"
            android:textColor="@color/text_secondary" />
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1000 lux"
            android:textColor="@color/text_secondary" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_card_rounded"
            android:backgroundTint="#161819"
            android:padding="16dp"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Library avg"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="420 lux"
                android:textColor="@color/primary_green"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_card_rounded"
            android:backgroundTint="#161819"
            android:padding="16dp"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginStart="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home avg"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="160 lux"
                android:textColor="#FFB74D"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Save"
        android:textColor="@color/white"
        android:backgroundTint="@color/primary_green"
        app:cornerRadius="28dp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_cancel"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Cancel"
        android:textColor="@color/text_secondary"
        android:backgroundTint="#00000000"
        app:strokeColor="#333333"
        app:strokeWidth="1dp"
        app:cornerRadius="28dp" />
</LinearLayout>