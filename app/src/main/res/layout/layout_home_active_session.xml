<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/card_current_env"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_rounded"
    android:orientation="vertical"
    android:padding="20dp"
    android:visibility="gone">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Current Environment"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="12dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_active_noise"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ 51 dB"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:background="#2A2C2E"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_active_light"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ 410 lux"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:background="#2A2C2E"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_active_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ 9:41 am"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:background="#2A2C2E"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp" />
        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>