<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_rounded"
    android:backgroundTint="#1A1C1E"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_filter_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filter by date range"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/ll_date_inputs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_filter_title">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:backgroundTint="#2A2C2E"
            android:padding="12dp"
            android:layout_marginEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FROM"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tv_from_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mar 10"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:backgroundTint="#2A2C2E"
            android:padding="12dp"
            android:layout_marginStart="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TO"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tv_to_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mar 16"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <GridLayout
        android:id="@+id/grid_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/ll_date_inputs">

        <TextView
            android:id="@+id/chip_7_days"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_height="wrap_content"
            android:text="Last 7 days"
            android:textColor="@color/white"
            android:background="@drawable/bg_card_rounded"
            android:backgroundTint="@color/primary_green"
            android:gravity="center"
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/chip_30_days"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_height="wrap_content"
            android:text="Last 30 days"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_card_rounded"
            android:backgroundTint="#00000000"
            android:gravity="center"
            android:padding="12dp"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/chip_this_month"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_height="wrap_content"
            android:text="This month"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_card_rounded"
            android:backgroundTint="#00000000"
            android:gravity="center"
            android:padding="12dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/chip_all_time"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_height="wrap_content"
            android:text="All time"
            android:textColor="@color/text_secondary"
            android:background="@drawable/bg_card_rounded"
            android:backgroundTint="#00000000"
            android:gravity="center"
            android:padding="12dp"
            android:layout_marginStart="8dp"/>
    </GridLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_apply_filter"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Apply Filter"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:cornerRadius="28dp"
        app:backgroundTint="@color/primary_green"
        app:layout_constraintTop_toBottomOf="@id/grid_chips" />

</androidx.constraintlayout.widget.ConstraintLayout>
