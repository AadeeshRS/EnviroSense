<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_rounded"
    android:backgroundTint="#1B1D1E"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_circular_progress"
        android:backgroundTint="#33E57373"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🗑"
            android:textColor="#E57373"
            android:textSize="24sp" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Delete all data?"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This will permanently erase all sessions, scores, and achievements. This action cannot be undone."
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btn_delete"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Yes, delete everything"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:backgroundTint="#B73A3A"
        app:cornerRadius="28dp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_cancel"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Cancel"
        android:textAllCaps="false"
        android:textColor="@color/text_secondary"
        android:backgroundTint="#00000000"
        app:strokeColor="#333333"
        app:strokeWidth="1dp"
        app:cornerRadius="28dp" />
</LinearLayout>