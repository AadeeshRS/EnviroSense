<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp">

    <!-- Your rank badge -->
    <LinearLayout
        android:id="@+id/card_your_rank"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_rounded"
        android:backgroundTint="#161819"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Rank circle -->
        <TextView
            android:id="@+id/tv_your_rank_number"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circular_progress"
            android:backgroundTint="@color/primary_green"
            android:gravity="center"
            android:text="#4"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_your_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_your_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Score: 82 · 24.5 hrs"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR RANK"
            android:textColor="@color/primary_green"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Tab toggle (same pattern as Analytics) -->
    <LinearLayout
        android:id="@+id/community_toggle_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="#161819"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/card_your_rank">

        <TextView
            android:id="@+id/tv_tab_leaderboard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_card_rounded"
            android:backgroundTint="#2A2C2E"
            android:gravity="center"
            android:padding="10dp"
            android:text="Leaderboard"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_tab_groups"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_card_rounded"
            android:backgroundTint="#00000000"
            android:gravity="center"
            android:padding="10dp"
            android:text="Groups"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Leaderboard RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_leaderboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/community_toggle_container" />

    <!-- Groups RecyclerView (hidden by default) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_groups"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/community_toggle_container" />

</androidx.constraintlayout.widget.ConstraintLayout>
