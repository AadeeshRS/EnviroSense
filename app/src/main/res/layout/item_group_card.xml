<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_rounded"
    android:backgroundTint="#161819"
    android:padding="16dp">

    <!-- Group emoji / icon -->
    <TextView
        android:id="@+id/tv_group_emoji"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_circular_progress"
        android:backgroundTint="#2A2C2E"
        android:gravity="center"
        android:text="📚"
        android:textSize="22sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Custom User Uploaded Icon -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_group_icon_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_group_icon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone" />
    </androidx.cardview.widget.CardView>

    <!-- Group name -->
    <TextView
        android:id="@+id/tv_group_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Library Legends"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/btn_more_options"
        app:layout_constraintStart_toEndOf="@id/tv_group_emoji"
        app:layout_constraintTop_toTopOf="@id/tv_group_emoji" />

    <!-- 3-Dot Options Menu (Hidden by default, used for Compact Mode) -->
    <ImageView
        android:id="@+id/btn_more_options"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="6dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_more_vert"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_group_emoji"
        app:layout_constraintBottom_toBottomOf="@id/tv_group_emoji"
        app:tint="@color/text_secondary" />

    <!-- Subject chips (scrollable) -->
    <HorizontalScrollView
        android:id="@+id/subject_scroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="14dp"
        android:scrollbars="none"
        android:fadingEdgeLength="16dp"
        android:requiresFadingEdge="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tv_group_name"
        app:layout_constraintStart_toEndOf="@id/tv_group_emoji"
        app:layout_constraintEnd_toStartOf="@+id/btn_more_options">

        <LinearLayout
            android:id="@+id/subject_rows"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />

    </HorizontalScrollView>
    <TextView
        android:id="@+id/tv_group_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Daily study sessions at the campus library"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tv_group_emoji"
        app:layout_constraintTop_toBottomOf="@id/subject_scroll" />

    <!-- Stats row -->
    <LinearLayout
        android:id="@+id/stats_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tv_group_desc">

        <!-- Members stat -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_member_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Members"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Avg Score stat -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_avg_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="78"
                android:textColor="@color/primary_green"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Avg Focus Score"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- View button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_view_group"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="View"
            android:textSize="12sp"
            app:backgroundTint="@color/primary_green"
            android:textColor="@color/black" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
