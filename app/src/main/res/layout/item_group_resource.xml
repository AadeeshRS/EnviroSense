<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_resource_item"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <!-- File type emoji icon -->
    <TextView
        android:id="@+id/tv_resource_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_circle_dark"
        android:gravity="center"
        android:text="📄"
        android:textSize="22sp" />

    <!-- File info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_resource_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Document.pdf"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="@font/poppins" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_resource_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.2 MB"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/poppins" />

            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_circle_dark" />

            <TextView
                android:id="@+id/tv_resource_uploader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="by User"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/poppins" />
        </LinearLayout>
    </LinearLayout>

    <!-- Overflow / type badge -->
    <TextView
        android:id="@+id/tv_resource_type_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_subject_chip"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:text="PDF"
        android:textColor="@color/primary_green"
        android:textSize="10sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins_bold" />

</LinearLayout>
